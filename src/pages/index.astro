---
import { getCollection } from 'astro:content';
import EventSubscription from '../components/EventSubscription.astro';
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import { isFuture, localDate, sortEvents, slug } from '../lib/events';

const now = new Date();
const [events, groups, venues, topics] = await Promise.all([
  getCollection('events'),
  getCollection('groups'),
  getCollection('venues'),
  getCollection('topics'),
]);
const future = sortEvents(
  events.filter((event) => isFuture(event, now)),
  true,
);
const past = sortEvents(
  events.filter((event) => !isFuture(event, now)),
  false,
);
const sorted = [...future, ...past];
const usedTopics = topics
  .filter((topic) => events.some((event) => event.data.topics.some((ref) => ref.id === topic.id)))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
const topicSections = [
  { category: 'general', label: 'General Topics' },
  { category: 'programming-language', label: 'Programming Languages' },
] as const;
const locationMap = new Map<string, string>();
for (const venue of venues)
  if (events.some((event) => event.data.venue?.id === venue.id))
    locationMap.set(slug(venue.data.suburb), venue.data.suburb);
if (events.some((event) => event.data.format === 'online')) locationMap.set('online', 'Online');
const locationOptions: { value: string; values: string[]; label: string }[] = [];
let addedRichmondCremorne = false;
for (const [value, label] of locationMap) {
  if (value === 'online') continue;
  if (value === 'richmond' || value === 'cremorne') {
    if (!addedRichmondCremorne) {
      locationOptions.push({
        value: 'cremorne',
        values: ['cremorne', 'richmond'],
        label: 'Richmond & Cremorne',
      });
      addedRichmondCremorne = true;
    }
  } else {
    locationOptions.push({
      value,
      values: [value],
      label: value === 'melbourne' ? 'Melbourne CBD' : label,
    });
  }
}
const jsonLd = events
  .filter((event) => isFuture(event, now))
  .map((event) => {
    const group = groups.find((item) => item.id === event.data.group.id);
    const venue = venues.find((item) => item.id === event.data.venue?.id);
    return {
      '@context': 'https://schema.org',
      '@type': 'Event',
      name: event.data.title,
      startDate: event.data.allDay ? localDate(event.data.start) : event.data.start.toISOString(),
      endDate: event.data.end?.toISOString(),
      eventStatus: `https://schema.org/Event${event.data.status === 'cancelled' ? 'Cancelled' : event.data.status === 'postponed' ? 'Postponed' : 'Scheduled'}`,
      eventAttendanceMode: `https://schema.org/${event.data.format === 'online' ? 'OnlineEventAttendanceMode' : event.data.format === 'hybrid' ? 'MixedEventAttendanceMode' : 'OfflineEventAttendanceMode'}`,
      isAccessibleForFree: !event.data.paid,
      location: venue
        ? { '@type': 'Place', name: venue.data.name, address: venue.data.address }
        : { '@type': 'VirtualLocation', url: event.data.url },
      url: event.data.url,
      organizer: { '@type': 'Organization', name: group?.data.name, url: group?.data.websiteUrl },
    };
  });
const choices = {
  period: [
    ['future', 'Upcoming'],
    ['past', 'Past'],
    ['all', 'All'],
  ],
  eventType: [
    ['all', 'All'],
    ['meetup', 'Meetups'],
    ['conference', 'Conferences'],
  ],
  cost: [
    ['all', 'Free & Paid'],
    ['free', 'Free Only'],
    ['paid', 'Paid Only'],
  ],
  range: [
    ['', 'Any date'],
    ['today', 'Today'],
    ['week', 'This week'],
    ['next-week', 'Next week'],
    ['month', 'This month'],
  ],
  format: [
    ['in-person', 'In person'],
    ['online', 'Online'],
    ['any', 'Any type'],
  ],
};
---

<Layout>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <header class="mb-7">
    <h1 class="text-3xl md:text-5xl font-black">Find Melbourne’s best tech community events</h1>
    <p class="event-intro mt-3">
      Melb.dev is the best place to find, attend, speak at, and organise meetups, conferences, and
      events, and communities for developers and people working in tech in Melbourne. It's a free
      service, aiming to strengthen Melbourne's tech community and advance technical excellence.
    </p>
  </header>
  <section id="directory" data-kind="events" class="directory-layout">
    <aside class="filter-sidebar">
      <details class="filter-disclosure">
        <summary>Filters</summary>
        <form id="filters" class="cardx filter-form" aria-labelledby="filter-heading">
          <div class="filter-heading-row">
            <h2 id="filter-heading" class="text-lg font-bold">Find an event</h2>
            <button type="reset" class="reset-button" hidden>Reset</button>
          </div>
          <label class="block mt-3">
            Keyword Search
            <input name="q" class="input input-bordered w-full" type="search" autocomplete="off" />
          </label>
          <p class="filter-note">Enter at least 3 characters.</p>
          {
            Object.entries(choices).map(([name, options]) => (
              <fieldset class="choice-group">
                <>
                  <legend>
                    {name === 'range'
                      ? 'Date range'
                      : name === 'eventType'
                        ? 'Event Type'
                        : name[0].toUpperCase() + name.slice(1)}
                  </legend>
                  <div class="choice-list">
                    {options.map(([value, label], index) => (
                      <label class="filter-choice">
                        <input type="radio" name={name} value={value} checked={index === 0} />
                        <span>{label}</span>
                      </label>
                    ))}
                  </div>
                </>
              </fieldset>
            ))
          }
          <fieldset data-facet-group="location">
            <legend class="sr-only">Locations</legend>
            <details class="facet-disclosure" data-facet-disclosure open>
              <summary>
                Locations <span class="facet-selection" data-selected-count hidden></span>
              </summary>
              <div class="facet-options">
                {
                  locationOptions.map(({ value, values, label }) => (
                    <label class="check-option">
                      <>
                        <input
                          type="checkbox"
                          name="location"
                          value={value}
                          data-values={values.join(',')}
                          data-label={label}
                          data-labels={values.length > 1 ? 'Richmond,Cremorne' : undefined}
                        />
                        <span>
                          {label} <span class="facet-count" data-count-for={value} />
                        </span>
                      </>
                    </label>
                  ))
                }
              </div>
            </details>
          </fieldset>
          {
            topicSections.map(({ category, label }) => (
              <fieldset data-facet-group="topic">
                <legend class="sr-only">{label}</legend>
                <details class="facet-disclosure" data-facet-disclosure open>
                  <summary>
                    {label} <span class="facet-selection" data-selected-count hidden />
                  </summary>
                  <div class="facet-options">
                    {usedTopics
                      .filter((topic) => topic.data.category === category)
                      .map((topic) => (
                        <label class="check-option">
                          <>
                            <input
                              type="checkbox"
                              name="topic"
                              value={topic.id}
                              data-label={topic.data.name}
                            />
                            <span>
                              {topic.data.name}{' '}
                              <span class="facet-count" data-count-for={topic.id} />
                            </span>
                          </>
                        </label>
                      ))}
                  </div>
                </details>
              </fieldset>
            ))
          }
        </form>
      </details>
    </aside>
    <div class="directory-results">
      <p id="count" class="result-summary font-semibold" role="status" aria-live="polite">
        {future.length} in person events upcoming
      </p>
      <div id="results" class="grid gap-4 md:grid-cols-2">
        {
          sorted.map((event) => (
            <EventCard
              event={event}
              groups={groups}
              venues={venues}
              topics={topics}
              period={isFuture(event, now) ? 'future' : 'past'}
              hideUntilFiltered={true}
            />
          ))
        }
      </div>
      <p id="empty" class="cardx hidden">
        No events match these filters. Try resetting your search.
      </p>
    </div>
  </section>
  <section class="cardx mt-8" aria-labelledby="subscribe">
    <EventSubscription />
  </section>
  <script src="../scripts/search.js"></script>
</Layout>
