    "tailwindcss": "4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.6",
    "@types/node": "24.0.14",
    "oxlint": "1.74.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "yaml": "2.8.0"
